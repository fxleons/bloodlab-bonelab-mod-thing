<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <OutputPath>build_out</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AssemblyName>BloodLabMod</AssemblyName>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <UseStubs Condition=" '$(UseStubs)' == '' ">false</UseStubs>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\ModSource\**\*.cs" />
  </ItemGroup>

  <ItemGroup Condition=" '$(UseStubs)' == 'true' ">
    <Compile Include="stubs\**\*.cs" />
  </ItemGroup>

  <ItemGroup Condition=" '$(UseStubs)' != 'true' ">
    <Reference Include="MelonLoader">
      <HintPath>$(MELON_DLL)</HintPath>
      <Private>false</Private>
    </Reference>

    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(UNITY_REF_DIR)\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <Reference Include="UnityEngine.PhysicsModule">
      <HintPath>$(UNITY_REF_DIR)\UnityEngine.PhysicsModule.dll</HintPath>
      <Private>false</Private>
    </Reference>

    <Reference Include="UnityEngine.AnimationModule">
      <HintPath>$(UNITY_REF_DIR)\UnityEngine.AnimationModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <Target Name="ValidateReferences" BeforeTargets="Build">
    <Error Condition=" '$(UseStubs)' != 'true' and ( '$(UNITY_REF_DIR)' == '' Or '$(MELON_DLL)' == '' ) "
           Text="missing UNITY_REF_DIR or MELON_DLL its ggs" />
  </Target>

  <Target Name="CopyBuildOutput" AfterTargets="Build">
    <PropertyGroup>
      <RootBuildOut>$(MSBuildProjectDirectory)/../build_out</RootBuildOut>
    </PropertyGroup>

    <MakeDir Directories="$(RootBuildOut)" />

    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll"
          DestinationFolder="$(RootBuildOut)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>