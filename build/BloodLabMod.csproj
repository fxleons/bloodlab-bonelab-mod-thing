<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <OutputPath>build_out</OutputPath>
    <AssemblyName>Bloodworks_RagdollCompatible_Bonelab</AssemblyName>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <UseStubs Condition=" '$(UseStubs)' == '' ">false</UseStubs>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\ModSource\**\*.cs" />
  </ItemGroup>
  <ItemGroup Condition=" '$(UseStubs)' == 'true' ">
    <Compile Include="stubs\**\*.cs" />
  </ItemGroup>
  <ItemGroup Condition=" '$(UseStubs)' != 'true' ">
    <Reference Include="UnityEngine">
      <HintPath>$(UNITY_DLL)</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="MelonLoader">
      <HintPath>$(MELON_DLL)</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  <Target Name="ValidateReferences" BeforeTargets="Build">
    <Error Condition=" '$(UseStubs)' != 'true' and ( '$(UNITY_DLL)' == '' Or '$(MELON_DLL)' == '' ) " Text="Missing UNITY_DLL or MELON_DLL. Provide actual UnityEngine.dll and MelonLoader.dll references for a real build." />
  </Target>
  <ItemGroup Condition=" '$(UNITY_DLL)' != '' ">
    <Reference Include="UnityEngine">
      <HintPath>$(UNITY_DLL)</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup Condition=" '$(MELON_DLL)' != '' ">
    <Reference Include="MelonLoader">
      <HintPath>$(MELON_DLL)</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
